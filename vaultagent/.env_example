# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=dein-bot-token
# TELEGRAM_WEBHOOK_URL=https://deine-domain.tld/telegram/webhook  # Nur setzen wenn öffentlich erreichbar, sonst wird Polling genutzt
# PORT=8080                                                        # Port für Webhook-Server (default: 8080)

# ── Zeitzone ──────────────────────────────────────────────
TIMEZONE=Europe/Berlin

# ── LLM (OpenAI-kompatibel) ──────────────────────────────
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=                                                  # Optionaler Fallback, falls LLM_API_KEY nicht gesetzt

# ── Website-Chat (optional) ──────────────────────────────
# WEBSITE_PORT=3000                                                # Port für den Website-Chat (default: 3000)
# WEBSITE_CHAT_ID=1                                                # Feste Chat-ID für Website-Nutzer

# ── Verzeichnisse (optional, Defaults in Klammern) ───────
# SOUL_DIR=soul                                                    # Persönlichkeit + Gedächtnis (default: soul)
# CRON_DIR=cron                                                    # Cron-Job-Speicher (default: cron)
# PYTHON_SKILLS_DIR=skills                                         # Python-Skills-Verzeichnis (default: skills)
