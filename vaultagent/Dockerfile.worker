# Sandbox worker image for VaultAgent.
# Expects the pre-compiled static binary to be in the build context.
#
# Build:  docker build -f Dockerfile.worker -t vaultagent-worker .
# Run:    see docker-compose.yml

FROM python:3.11-slim-bookworm

# Install sudo so the worker can install packages at runtime (e.g. apt-get install git)
RUN apt-get update && apt-get install -y --no-install-recommends sudo \
    && rm -rf /var/lib/apt/lists/*

# Create a user with UID 1000 to match the typical host user.
RUN useradd --uid 1000 --create-home --shell /bin/bash worker \
    && echo 'worker ALL=(ALL) NOPASSWD: /usr/bin/apt-get, /usr/bin/apt, /usr/bin/dpkg, /usr/bin/pip, /usr/bin/pip3' >> /etc/sudoers.d/worker

# Copy the statically-linked binary (cross-compiled for the target arch)
COPY vaultagent /usr/local/bin/vaultagent
RUN chmod +x /usr/local/bin/vaultagent

# Seed workspace defaults (copied into the named volume on first run).
COPY skills /workspace/skills
RUN mkdir -p /workspace/uploads

WORKDIR /workspace
USER worker

EXPOSE 9100

CMD ["vaultagent", "--worker"]
