# ┌─────────────────────────────────────────────────────────┐
# │  .env.secure — HOST-ONLY secrets                       │
# │  This file is loaded by the orchestrator (systemd).    │
# │  These values NEVER enter the Docker sandbox.          │
# └─────────────────────────────────────────────────────────┘

# ── General User for Web Interface ──
USERNAME=admin
PASSWORD=supersecretpassword

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=your-chat-id
# TELEGRAM_WEBHOOK_URL=https://your-domain.tld/telegram/webhook
# PORT=8080

# ── OpenAI / OpenAI-compatible ────────────────────────────
# Optional. If configured, provider/model can be switched at runtime via /models.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────────────────
# Optional. If configured, provider/model can be switched at runtime via /models.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Timezone ──────────────────────────────────────────────
TIMEZONE=Europe/Berlin

# ── Sandbox worker (required) ─────────────────────────────
# All skills execute inside the Docker sandbox worker.
WORKER_URL=http://localhost:9100
WORKER_TOKEN=change-me-to-a-random-secret

# ── Mailbox (optional; host-side skill) ──────────────────
# Fill with your provider settings (IONOS, Gmail, Proton Bridge, own server, ...).
MAILBOX_EMAIL_ADDRESS=bot@example.com
MAILBOX_EMAIL_PASSWORD=change-me
MAILBOX_IMAP_HOST=imap.example.com
MAILBOX_IMAP_PORT=993
MAILBOX_POP3_HOST=pop.example.com
MAILBOX_POP3_PORT=995
MAILBOX_SMTP_HOST=smtp.example.com
MAILBOX_SMTP_PORT=587

# ── GitHub (optional; host-side skill) ───────────────────
# Recommended for cross-owner collaborator clones: use a Classic PAT from a
# dedicated bot account (scope: repo). For org repos, authorize SSO if required.
GITHUB_TOKEN=
# GITHUB_API_BASE_URL is optional (only needed for GitHub Enterprise hosts).
