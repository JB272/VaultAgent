# ┌─────────────────────────────────────────────────────────┐
# │  .env.docker — WORKER (Docker sandbox) environment     │
# │  Only non-secret config belongs here.                  │
# │  Add your own API keys here ONLY if a Python skill     │
# │  inside the sandbox needs them.                        │
# └─────────────────────────────────────────────────────────┘

# ── Worker auth (must match WORKER_TOKEN in .env.secure) ──
WORKER_TOKEN=change-me-to-a-random-secret

# ── Worker settings ──────────────────────────────────────
WORKER_PORT=9100

# ── Paths inside the container (match docker-compose mounts) ──
SOUL_DIR=/workspace/soul
CRON_DIR=/workspace/cron
PYTHON_SKILLS_DIR=/workspace/skills

# ── Your custom keys for Python skills (examples) ────────
# MY_CUSTOM_API_KEY=...
# WEATHER_API_KEY=...
